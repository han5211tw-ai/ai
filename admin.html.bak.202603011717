<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin 資料管理中心 | 電腦舖</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Microsoft JhengHei', sans-serif;
            background: #0f172a;
            color: #e2e8f0;
            min-height: 100vh;
        }
        .login-section {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        }
        .login-box {
            background: rgba(30, 41, 59, 0.95);
            border: 1px solid rgba(148, 163, 184, 0.2);
            border-radius: 16px;
            padding: 40px;
            width: 400px;
            text-align: center;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .login-box h1 {
            color: #38bdf8;
            font-size: 1.8em;
            margin-bottom: 10px;
        }
        .login-box .subtitle {
            color: #94a3b8;
            font-size: 0.9em;
            margin-bottom: 30px;
        }
        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }
        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #cbd5e1;
            font-size: 0.9em;
        }
        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid rgba(148, 163, 184, 0.3);
            border-radius: 8px;
            background: rgba(15, 23, 42, 0.8);
            color: #e2e8f0;
            font-size: 1em;
        }
        .form-group input:focus {
            outline: none;
            border-color: #38bdf8;
        }
        .btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #0ea5e9, #0284c7);
            color: white;
            font-size: 1em;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(14, 165, 233, 0.3);
        }
        .error-msg {
            color: #f87171;
            margin-top: 15px;
            font-size: 0.9em;
        }
        
        /* Dashboard Styles */
        .dashboard {
            display: none;
        }
        .dashboard.active {
            display: block;
        }
        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            width: 260px;
            height: 100vh;
            background: rgba(15, 23, 42, 0.98);
            border-right: 1px solid rgba(148, 163, 184, 0.1);
            padding: 20px 0;
            overflow-y: auto;
        }
        .sidebar-header {
            padding: 0 20px 20px;
            border-bottom: 1px solid rgba(148, 163, 184, 0.1);
            margin-bottom: 20px;
        }
        .sidebar-header h2 {
            color: #38bdf8;
            font-size: 1.3em;
        }
        .sidebar-header .user-info {
            color: #94a3b8;
            font-size: 0.85em;
            margin-top: 5px;
        }
        .nav-section {
            margin-bottom: 25px;
        }
        .nav-title {
            padding: 0 20px;
            color: #64748b;
            font-size: 0.75em;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 10px;
        }
        .nav-item {
            display: block;
            padding: 12px 20px;
            color: #cbd5e1;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }
        .nav-item:hover, .nav-item.active {
            background: rgba(56, 189, 248, 0.1);
            color: #38bdf8;
            border-left-color: #38bdf8;
        }
        .nav-item .icon {
            display: inline-block;
            width: 24px;
            margin-right: 10px;
        }
        .main-content {
            margin-left: 260px;
            padding: 30px;
        }
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        .page-header h1 {
            font-size: 1.8em;
            color: #f1f5f9;
        }
        
        /* Audit Cards */
        .audit-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .audit-card {
            background: rgba(30, 41, 59, 0.6);
            border: 1px solid rgba(148, 163, 184, 0.15);
            border-radius: 12px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .audit-card:hover {
            transform: translateY(-3px);
            border-color: rgba(56, 189, 248, 0.3);
            box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.3);
        }
        .audit-card.alert-high {
            border-left: 4px solid #ef4444;
        }
        .audit-card.alert-medium {
            border-left: 4px solid #f59e0b;
        }
        .audit-card.alert-low {
            border-left: 4px solid #10b981;
        }
        .audit-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        .audit-card-title {
            font-size: 0.9em;
            color: #94a3b8;
        }
        .audit-card-count {
            font-size: 2em;
            font-weight: bold;
            color: #f1f5f9;
        }
        .audit-card-desc {
            font-size: 0.85em;
            color: #64748b;
            line-height: 1.5;
        }
        
        /* Data Table */
        .data-table-container {
            background: rgba(30, 41, 59, 0.6);
            border: 1px solid rgba(148, 163, 184, 0.15);
            border-radius: 12px;
            overflow: hidden;
        }
        .table-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            border-bottom: 1px solid rgba(148, 163, 184, 0.1);
            gap: 15px;
        }
        .search-box {
            display: flex;
            gap: 10px;
            flex: 1;
        }
        .search-box input {
            flex: 1;
            padding: 10px 15px;
            border: 1px solid rgba(148, 163, 184, 0.2);
            border-radius: 8px;
            background: rgba(15, 23, 42, 0.8);
            color: #e2e8f0;
        }
        .btn-small {
            padding: 8px 16px;
            font-size: 0.85em;
            width: auto;
        }
        .btn-secondary {
            background: linear-gradient(135deg, #64748b, #475569);
        }
        .btn-danger {
            background: linear-gradient(135deg, #ef4444, #dc2626);
        }
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }
        .data-table th {
            background: rgba(15, 23, 42, 0.8);
            padding: 12px 15px;
            text-align: left;
            color: #94a3b8;
            font-weight: 500;
            font-size: 0.85em;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .data-table td {
            padding: 12px 15px;
            border-bottom: 1px solid rgba(148, 163, 184, 0.1);
            color: #e2e8f0;
        }
        .data-table tr:hover td {
            background: rgba(56, 189, 248, 0.05);
        }
        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.75em;
            font-weight: 500;
        }
        .badge-pending {
            background: rgba(245, 158, 11, 0.2);
            color: #f59e0b;
        }
        .badge-resolved {
            background: rgba(16, 185, 129, 0.2);
            color: #10b981;
        }
        .badge-cancelled {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
        }
        
        /* Modal */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        .modal-overlay.active {
            display: flex;
        }
        .modal {
            background: rgba(30, 41, 59, 0.98);
            border: 1px solid rgba(148, 163, 184, 0.2);
            border-radius: 16px;
            width: 90%;
            max-width: 700px;
            max-height: 90vh;
            overflow-y: auto;
        }
        .modal-header {
            padding: 20px;
            border-bottom: 1px solid rgba(148, 163, 184, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-header h3 {
            color: #f1f5f9;
        }
        .modal-close {
            background: none;
            border: none;
            color: #94a3b8;
            font-size: 1.5em;
            cursor: pointer;
        }
        .modal-body {
            padding: 20px;
        }
        .modal-footer {
            padding: 15px 20px;
            border-top: 1px solid rgba(148, 163, 184, 0.1);
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }
        
        /* Diff View */
        .diff-view {
            background: rgba(15, 23, 42, 0.8);
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
        }
        .diff-row {
            display: flex;
            gap: 20px;
            margin-bottom: 10px;
        }
        .diff-label {
            width: 80px;
            color: #64748b;
            font-size: 0.85em;
        }
        .diff-old {
            flex: 1;
            color: #ef4444;
            text-decoration: line-through;
            background: rgba(239, 68, 68, 0.1);
            padding: 8px;
            border-radius: 4px;
        }
        .diff-new {
            flex: 1;
            color: #10b981;
            background: rgba(16, 185, 129, 0.1);
            padding: 8px;
            border-radius: 4px;
        }
        
        /* Loading */
        .loading {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 2000;
        }
        .loading.active {
            display: block;
        }
        .spinner {
            width: 50px;
            height: 50px;
            border: 3px solid rgba(56, 189, 248, 0.3);
            border-top-color: #38bdf8;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Toast */
        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            padding: 15px 25px;
            border-radius: 8px;
            color: white;
            z-index: 3000;
            transform: translateX(400px);
            transition: transform 0.3s;
        }
        .toast.show {
            transform: translateX(0);
        }
        .toast.success {
            background: linear-gradient(135deg, #10b981, #059669);
        }
        .toast.error {
            background: linear-gradient(135deg, #ef4444, #dc2626);
        }
    </style>
</head>
<body>
    <!-- Login Section -->
    <div id="loginSection" class="login-section">
        <div class="login-box">
            <h1>🔐 Admin 資料管理中心</h1>
            <p class="subtitle">僅限授權管理員訪問</p>
            <div class="form-group">
                <label>管理員密碼</label>
                <input type="password" id="adminPassword" placeholder="輸入4位數字密碼" maxlength="4">
            </div>
            <button class="btn" onclick="login()">登入</button>
            <div id="loginError" class="error-msg"></div>
        </div>
    </div>

    <!-- Dashboard -->
    <div id="dashboard" class="dashboard">
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>📊 資料管理中心</h2>
                <div class="user-info">
                    <span id="adminName">-</span> | <a href="#" onclick="logout()" style="color:#94a3b8;">登出</a>
                </div>
            </div>
            
            <div class="nav-section">
                <div class="nav-title">稽核檢查</div>
                <a class="nav-item active" onclick="showPage('audit')">
                    <span class="icon">🔍</span>稽核儀表
                </a>
            </div>
            
            <div class="nav-section">
                <div class="nav-title">資料管理</div>
                <a class="nav-item" onclick="showPage('needs')">
                    <span class="icon">📝</span>需求單 (needs)
                </a>
                <a class="nav-item" onclick="showPage('staging')">
                    <span class="icon">⏳</span>待建檔中心
                </a>
                <a class="nav-item" onclick="showPage('customers')">
                    <span class="icon">👥</span>客戶主檔
                </a>
                <a class="nav-item" onclick="showPage('products')">
                    <span class="icon">📦</span>產品主檔
                </a>
                <a class="nav-item" onclick="showPage('inventory')">
                    <span class="icon">🏭</span>庫存管理
                </a>
            </div>
            
            <div class="nav-section">
                <div class="nav-title">交易紀錄</div>
                <a class="nav-item" onclick="showPage('purchase')">
                    <span class="icon">📥</span>進貨紀錄
                </a>
                <a class="nav-item" onclick="showPage('sales')">
                    <span class="icon">📤</span>銷貨紀錄
                </a>
            </div>
            
            <div class="nav-section">
                <div class="nav-title">系統</div>
                <a class="nav-item" onclick="showPage('audit_log')">
                    <span class="icon">📋</span>操作日誌
                </a>
            </div>
        </aside>

        <main class="main-content">
            <!-- Audit Dashboard -->
            <div id="page-audit" class="page-content">
                <div class="page-header">
                    <h1>🔍 稽核儀表</h1>
                    <button class="btn btn-small" onclick="refreshAudit()">重新整理</button>
                </div>
                
                <div class="audit-grid" id="auditCards">
                    <!-- Cards will be loaded dynamically -->
                </div>
            </div>

            <!-- Data Management Pages -->
            <div id="page-needs" class="page-content" style="display:none;">
                <div class="page-header">
                    <h1>📝 需求單管理</h1>
                </div>
                <div class="data-table-container">
                    <div class="table-toolbar">
                        <div class="search-box">
                            <input type="text" id="needsSearch" placeholder="搜尋：品名、編號、客戶、填表人...">
                            <button class="btn btn-small" onclick="searchTable('needs')">搜尋</button>
                        </div>
                        <div>
                            <select id="needsFilter" onchange="filterTable('needs')">
                                <option value="">全部狀態</option>
                                <option value="待處理">待處理</option>
                                <option value="已取消">已取消</option>
                                <option value="已完成">已完成</option>
                            </select>
                        </div>
                    </div>
                    <table class="data-table" id="needsTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>日期</th>
                                <th>產品</th>
                                <th>數量</th>
                                <th>部門</th>
                                <th>填表人</th>
                                <th>狀態</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>

            <!-- Other pages will be loaded dynamically -->
        </main>
    </div>

    <!-- Edit Modal -->
    <div id="editModal" class="modal-overlay">
        <div class="modal">
            <div class="modal-header">
                <h3>✏️ 編輯資料</h3>
                <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body" id="modalBody">
                <!-- Form will be loaded dynamically -->
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal()">取消</button>
                <button class="btn" onclick="saveChanges()">儲存變更</button>
            </div>
        </div>
    </div>

    <!-- Loading Spinner -->
    <div id="loading" class="loading">
        <div class="spinner"></div>
    </div>

    <!-- Toast -->
    <div id="toast" class="toast"></div>

    <script>
        // Global state
        let currentAdmin = null;
        let currentEditData = null;
        
        // Login
        async function login() {
            const password = document.getElementById('adminPassword').value.trim();
            if (password.length !== 4) {
                showError('請輸入4位數字密碼');
                return;
            }
            
            try {
                const response = await fetch('/api/auth/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ password: password })
                });
                
                const data = await response.json();
                
                if (data.success && (data.name === '黃柏翰' || data.title === '老闆')) {
                    currentAdmin = data;
                    document.getElementById('loginSection').style.display = 'none';
                    document.getElementById('dashboard').classList.add('active');
                    document.getElementById('adminName').textContent = data.name;
                    loadAuditSummary();
                } else {
                    showError('無權限訪問 Admin 系統');
                }
            } catch (error) {
                showError('登入失敗，請稍後再試');
            }
        }
        
        function logout() {
            currentAdmin = null;
            document.getElementById('dashboard').classList.remove('active');
            document.getElementById('loginSection').style.display = 'flex';
            document.getElementById('adminPassword').value = '';
        }
        
        function showError(msg) {
            document.getElementById('loginError').textContent = msg;
        }
        
        // Navigation
        function showPage(page) {
            document.querySelectorAll('.page-content').forEach(el => el.style.display = 'none');
            document.getElementById('page-' + page).style.display = 'block';
            document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
            event.target.classList.add('active');
            
            if (page !== 'audit') {
                loadTableData(page);
            }
        }
        
        // Load Audit Summary
        async function loadAuditSummary() {
            showLoading(true);
            try {
                const response = await fetch('/api/admin/audit/summary?admin=' + encodeURIComponent(currentAdmin.name));
                const data = await response.json();
                
                if (data.success) {
                    renderAuditCards(data.checks);
                } else {
                    console.error('Audit Summary Error:', data.message);
                    showToast('載入稽核資料失敗: ' + (data.message || '未知錯誤'), 'error');
                }
            } catch (error) {
                console.error('Audit Summary Exception:', error);
                showToast('載入稽核資料失敗: 網路錯誤', 'error');
            }
            showLoading(false);
        }
        
        function renderAuditCards(checks) {
            const container = document.getElementById('auditCards');
            const cards = [
                { code: 'A1', title: 'Staging 已 resolved 但 needs 未回填', desc: '客戶/產品 staging 狀態為 resolved，但對應 needs 的 code 仍為空', level: 'high' },
                { code: 'A2', title: 'Staging pending 但 needs 已有正式碼', desc: '狀態不一致，可能為人工直接修改 needs 導致', level: 'medium' },
                { code: 'A3', title: 'Needs 指到不存在的正式主檔', desc: 'customer_code/product_code 在 master 表中找不到', level: 'high' },
                { code: 'A4', title: '同手機重複 customer staging', desc: '去重機制失效，同一手機有多筆 pending staging', level: 'medium' },
                { code: 'A5', title: 'Products 同名多 product_code', desc: '疑似重複建檔，同名產品有多個編號', level: 'low' }
            ];
            
            container.innerHTML = cards.map(card => {
                const count = checks[card.code] || 0;
                return `
                    <div class="audit-card alert-${card.level}" onclick="showAuditDetail('${card.code}')">
                        <div class="audit-card-header">
                            <span class="audit-card-title">${card.code}: ${card.title}</span>
                            <span class="audit-card-count">${count}</span>
                        </div>
                        <div class="audit-card-desc">${card.desc}</div>
                    </div>
                `;
            }).join('');
        }
        
        async function showAuditDetail(code) {
            showLoading(true);
            try {
                const response = await fetch('/api/admin/audit/detail?code=' + code + '&admin=' + encodeURIComponent(currentAdmin.name));
                const data = await response.json();
                
                if (data.success) {
                    // Show detail modal with fix options
                    showAuditDetailModal(code, data.items);
                }
            } catch (error) {
                showToast('載入明細失敗', 'error');
            }
            showLoading(false);
        }
        
        // Table Operations
        async function loadTableData(table) {
            showLoading(true);
            try {
                const response = await fetch('/api/admin/table?name=' + table + '&limit=100&admin=' + encodeURIComponent(currentAdmin.name));
                const data = await response.json();
                
                if (data.success) {
                    renderTable(table, data.items);
                }
            } catch (error) {
                showToast('載入資料失敗', 'error');
            }
            showLoading(false);
        }
        
        function renderTable(table, items) {
            const tbody = document.querySelector('#' + table + 'Table tbody');
            // Implementation depends on table structure
        }
        
        // Modal Operations
        function showAuditDetailModal(code, items) {
            // Implementation
        }
        
        function closeModal() {
            document.getElementById('editModal').classList.remove('active');
        }
        
        // Utilities
        function showLoading(show) {
            document.getElementById('loading').classList.toggle('active', show);
        }
        
        function showToast(message, type) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.className = 'toast ' + type + ' show';
            setTimeout(() => toast.classList.remove('show'), 3000);
        }
        
        function refreshAudit() {
            loadAuditSummary();
        }
    </script>
</body>
</html>
